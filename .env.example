PORT=4000
OPENAI_API_KEY=

# SQLite (ruta relativa al cwd o absoluta)
DATABASE_PATH=data/chat.db

# Contexto enviado al modelo (máx. mensajes user+assistant, incluye el nuevo)
CHAT_HISTORY_MAX_MESSAGES=24

# Rate limit sobre rutas /chat (ventana en ms y máx. peticiones por IP)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=120

CORS_ORIGIN=*
NODE_ENV=development

# Tras nginx / load balancer: TRUST_PROXY=true
TRUST_PROXY=false

# Calendario del restaurante (IANA)
RESTAURANT_TIMEZONE=Europe/Madrid
# Días mostrados al modelo y en GET /api/schedule (1–31)
SCHEDULE_CONTEXT_DAYS=14

# Reservas y capacidad
RESTAURANT_TABLE_COUNT=15
SEATS_PER_TABLE=4
RESERVATION_LUNCH_DURATION_MIN=90
RESERVATION_DINNER_DURATION_MIN=120
AVAILABILITY_SLOT_STEP_MIN=30
ASSISTANT_TOOL_MAX_ROUNDS=6
# Segundos: misma sesión + misma fecha/hora/comensales → no duplica reserva (30–900)
RESERVATION_IDEMPOTENCY_WINDOW_SEC=120

# Marca en emails de confirmación
RESTAURANT_NAME=Tu Restaurante

# URL pública (https://tu-dominio.com) para Open Graph / metas en el cliente; opcional
PUBLIC_BASE_URL=

# Panel calendario /reservas.html y API /api/admin/* (cabecera X-Admin-Key). Genera una clave larga aleatoria.
ADMIN_API_KEY=

# Correo de confirmación (obligatorio usuario+contraseña salvo relay interno)
# Gmail: crear "contraseña de aplicación"; MAIL_FROM suele ser la misma cuenta.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
# Solo relays sin login: SMTP_ALLOW_NO_AUTH=true
SMTP_ALLOW_NO_AUTH=false
